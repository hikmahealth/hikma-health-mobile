{
  "name": "Hikma Health",
  "slug": "hikma-health-mobile",
  "scheme": "hikma-health-mobile",
  "version": "1.5.6",
  "orientation": "default",
  "userInterfaceStyle": "light",
  "icon": "./assets/images/app-icon-all.png",
  "updates": {
    "fallbackToCacheTimeout": 0,
    "url": "https://u.expo.dev/9e7488c0-10e5-4ccc-95a6-bd154d0129b1"
  },
  "newArchEnabled": true,
  "jsEngine": "hermes",
  "assetBundlePatterns": ["**/*"],
  "android": {
    "icon": "./assets/images/app-icon-android-legacy.png",
    "package": "com.hikmahealth",
    "userInterfaceStyle": "light",
    "adaptiveIcon": {
      "foregroundImage": "./assets/images/app-icon-android-adaptive-foreground.png",
      "backgroundImage": "./assets/images/app-icon-android-adaptive-background.png"
    },
    "allowBackup": false,
    "edgeToEdgeEnabled": true,
    "versionCode": 56,
    "versionName": "1.5.6"
  },
  "ios": {
    "icon": "./assets/images/app-icon-ios.png",
    "supportsTablet": true,
    "requireFullScreen": true,
    "bundleIdentifier": "com.hikmahealth",
    "userInterfaceStyle": "light",
    "privacyManifests": {
      "NSPrivacyAccessedAPITypes": [
        {
          "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
          "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
        },
        {
          "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
          "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
        },
        {
          "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
          "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
        }
      ]
    },
    "infoPlist": {
      "ITSAppUsesNonExemptEncryption": false
    },
    "appleTeamId": "495PXWBS5B"
  },
  "web": {
    "favicon": "./assets/images/app-icon-web-favicon.png",
    "bundler": "metro"
  },
  "plugins": [
    [
      "expo-build-properties",
      {
        "ios": {
          "infoPlist": {
            "NSAppTransportSecurity": {
              "NSAllowsLocalNetworking": true
            }
          },
          "extraPods": [
            {
              "name": "simdjson",
              "configurations": ["Debug", "Release"],
              "path": "../node_modules/@nozbe/simdjson",
              "modular_headers": true
            }
          ]
        },
        "android": {
          "usesCleartextTraffic": true,
          "packagingOptions": {
            "pickFirst": ["**/libc++_shared.so"]
          }
        }
      }
    ],
    [
      "expo-screen-orientation",
      {
        "initialOrientation": "DEFAULT"
      }
    ],
    "expo-secure-store",
    "expo-localization",
    "expo-font",
    "expo-sharing",
    [
      "expo-splash-screen",
      {
        "image": "./assets/images/app-icon-android-adaptive-foreground.png",
        "imageWidth": 300,
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      }
    ],
    [
      "react-native-edge-to-edge",
      {
        "android": {
          "parentTheme": "Light",
          "enforceNavigationBarContrast": false
        }
      }
    ],
    [
      "expo-camera",
      {
        "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
        "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone",
        "recordAudioAndroid": true
      }
    ],
    [
      "@sentry/react-native/expo",
      {
        "url": "https://sentry.io/",
        "project": "react-native",
        "organization": "hikma-health"
      }
    ]
  ],
  "experiments": {
    "tsconfigPaths": true
  },
  "extra": {
    "ignite": {
      "version": "11.1.0"
    },
    "eas": {
      "projectId": "9e7488c0-10e5-4ccc-95a6-bd154d0129b1"
    }
  },
  "runtimeVersion": {
    "policy": "appVersion"
  }
}
