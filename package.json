{
  "name": "hikma-health-mobile",
  "version": "1.5.6",
  "private": true,
  "main": "index.tsx",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios --device",
    "web": "expo start --web",
    "bundle:web": "npx expo export --platform web",
    "serve:web": "npx serve dist",
    "prebuild:clean": "npx expo prebuild --clean",
    "compile": "tsc --noEmit -p . --pretty",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "align-deps": "npx expo install --fix",
    "postinstall": "./patch-packages.sh",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:badge": "bash scripts/update-coverage-badge.sh",
    "test:maestro": "maestro test -e MAESTRO_APP_ID=com.hikmahealth .maestro/flows @.env.maestro",
    "adb": "adb reverse tcp:9090 tcp:9090 && adb reverse tcp:3000 tcp:3000 && adb reverse tcp:9001 tcp:9001 && adb reverse tcp:8081 tcp:8081",
    "build:ios:sim": "eas build --profile development --platform ios --local",
    "build:ios:dev": "eas build --profile development:device --platform ios --local",
    "build:ios:preview": "eas build --profile preview --platform ios --local",
    "build:ios:prod": "eas build --profile production --platform ios --local",
    "build:android:sim": "eas build --profile development --platform android --local",
    "build:android:dev": "eas build --profile development:device --platform android --local",
    "build:android:preview": "eas build --profile preview --platform android --local",
    "build:android:prod": "eas build --profile production --platform android --local",
    "build:vendor:watermelondb": "cd vendor/LovesWorking/watermelondb-expo-plugin-sdk-52-plus && npx tsc --outDir build --rootDir src --target es2020 --module commonjs --moduleResolution node --declaration --esModuleInterop --allowSyntheticDefaultImports --skipLibCheck --resolveJsonModule src/withWatermelon.ts",
    "eas:update:prod": "eas update --channel production",
    "eas:submit:android": "eas submit --platform android",
    "eas:build:submit:android": "pnpm build:android:prod && eas submit --platform android",
    "eas:submit:ios": "eas submit --platform ios",
    "eas:build:submit:ios": "pnpm build:ios:prod && eas submit --platform ios",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@expo-google-fonts/space-grotesk": "^0.4.1",
